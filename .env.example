# Copy to .env and fill in if you have a price feed.
# Everything except live prices and the J.A.R.V.I.S. assistant works WITHOUT a key.
PRICE_API_KEY=
# J.A.R.V.I.S. assistant — your Anthropic API key (kept server-side, never shipped to the browser).
# Get one at https://console.anthropic.com . Without it, JARVIS runs in offline mode.
ANTHROPIC_API_KEY=
PORT=3000
